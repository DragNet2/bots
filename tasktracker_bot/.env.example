# Telegram Bot
BOT_TOKEN=your_telegram_bot_token

# Groq AI
GROQ_API_KEY=your_groq_api_key

# Task Tracker Web
TASKTRACKER_SECRET_KEY=change-me-to-a-random-secret
WEB_PORT=5001

# Admin
ADMIN_USER_IDS=your_telegram_user_id

# Google OAuth (optional)
TASKTRACKER_ALLOWED_EMAILS=email1@example.com,email2@example.com
TASKTRACKER_GOOGLE_CLIENT_ID=your_google_client_id
TASKTRACKER_GOOGLE_CLIENT_SECRET=your_google_client_secret
TASKTRACKER_GOOGLE_REDIRECT_URI=https://your-domain.com/auth/google/callback
