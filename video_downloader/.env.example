# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# VK Service Access Token (from https://dev.vk.com/)
# Settings -> Access Tokens -> Service Key
VK_SERVICE_ACCESS_TOKEN=your_vk_service_access_token_here

# Yandex OAuth Token (from https://oauth.yandex.ru/)
# Get token from: https://oauth.yandex.ru/authorize?response_type=code&client_id=YOUR_CLIENT_ID
YANDEX_TOKEN=your_yandex_oauth_token_here
